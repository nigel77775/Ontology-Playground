    <!-- ================== -->
    <!-- Object Properties -->
    <!-- ================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/fabric-data-quality-ontology/rel-relates-to-10">
        <rdfs:label>provides</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/fabric-data-quality-ontology/New-entity-2"/>
        <rdfs:range rdf:resource="http://example.org/ontology/fabric-data-quality-ontology/New-entity-8"/>
        <rdfs:comment>One or many data engineers provide a solution</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-2</ont:fromEntityId>
        <ont:toEntityId>new-entity-8</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/fabric-data-quality-ontology/rel-relates-to-9">
        <rdfs:label>originates_from</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/fabric-data-quality-ontology/New-entity-3"/>
        <rdfs:range rdf:resource="http://example.org/ontology/fabric-data-quality-ontology/New-entity-6"/>
        <rdfs:comment>Data quality issues originating from data pipeline</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-3</ont:fromEntityId>
        <ont:toEntityId>new-entity-6</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/fabric-data-quality-ontology/rel-relates-to-8">
        <rdfs:label>linkedto_known</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/fabric-data-quality-ontology/New-entity-3"/>
        <rdfs:range rdf:resource="http://example.org/ontology/fabric-data-quality-ontology/New-entity-7"/>
        <rdfs:comment>Data quality issue can be linked to a known rootcause</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-3</ont:fromEntityId>
        <ont:toEntityId>new-entity-7</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/fabric-data-quality-ontology/rel-relates-to-7">
        <rdfs:label>fixes</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/fabric-data-quality-ontology/New-entity-2"/>
        <rdfs:range rdf:resource="http://example.org/ontology/fabric-data-quality-ontology/New-entity-6"/>
        <rdfs:comment>DataEngineer fixes pipeline</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-2</ont:fromEntityId>
        <ont:toEntityId>new-entity-6</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/fabric-data-quality-ontology/rel-relates-to-6">
        <rdfs:label>works_on</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/fabric-data-quality-ontology/New-entity-2"/>
        <rdfs:range rdf:resource="http://example.org/ontology/fabric-data-quality-ontology/New-entity-3"/>
        <rdfs:comment>Dataengineer works on the data quality issues.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-2</ont:fromEntityId>
        <ont:toEntityId>new-entity-3</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/fabric-data-quality-ontology/rel-relates-to-5">
        <rdfs:label>reports</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/fabric-data-quality-ontology/New-entity-1"/>
        <rdfs:range rdf:resource="http://example.org/ontology/fabric-data-quality-ontology/New-entity-3"/>
        <rdfs:comment>User reports data quality issue</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-1</ont:fromEntityId>
        <ont:toEntityId>new-entity-3</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/fabric-data-quality-ontology/rel-relates-to-3">
        <rdfs:label>impacts</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/fabric-data-quality-ontology/New-entity-3"/>
        <rdfs:range rdf:resource="http://example.org/ontology/fabric-data-quality-ontology/New-entity-5"/>
        <rdfs:comment>Data quality issue impacts one or more data assets</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-3</ont:fromEntityId>
        <ont:toEntityId>new-entity-5</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
