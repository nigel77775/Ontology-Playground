<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/fabric-data-quality-ontology/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/fabric-data-quality-ontology/">

    <owl:Ontology rdf:about="http://example.org/ontology/fabric-data-quality-ontology/">
        <rdfs:label>Fabric Data Quality Ontology</rdfs:label>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/fabric-data-quality-ontology/New-entity-8">
        <rdfs:label>Resolution</rdfs:label>
        <rdfs:comment>Represents actions taken to resolve the issue.</rdfs:comment>
        <ont:icon>🎯</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/fabric-data-quality-ontology/New-entity-7">
        <rdfs:label>RootCause</rdfs:label>
        <rdfs:comment>Represents the identified root cause of the issues.</rdfs:comment>
        <ont:icon>📝</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/fabric-data-quality-ontology/New-entity-6">
        <rdfs:label>DataPipeline</rdfs:label>
        <rdfs:comment>Represents ingestion or transformation pipelines.</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/fabric-data-quality-ontology/New-entity-5">
        <rdfs:label>DataAssets</rdfs:label>
        <rdfs:comment>Represents Microsoft Fabric assets involved in the issue. (semantic models,reports, notebooks, LH,WH, dataflow etc)</rdfs:comment>
        <ont:icon>🛒</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/fabric-data-quality-ontology/New-entity-3">
        <rdfs:label>DataQualityIssues</rdfs:label>
        <rdfs:comment>Represents a reported data issue affecting analytics or reporting.</rdfs:comment>
        <ont:icon>📝</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/fabric-data-quality-ontology/New-entity-2">
        <rdfs:label>DataEngineer</rdfs:label>
        <rdfs:comment>Represents the engineer responsible for resolving data issues.</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#008272</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/fabric-data-quality-ontology/New-entity-1">
        <rdfs:label>User</rdfs:label>
        <rdfs:comment>Represents a person interacting with the data solutions/process</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

