        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/nauclasssearchontology/subject_subject_description">
        <rdfs:label>subject_description</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/nauclasssearchontology/Subject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
