    <owl:DatatypeProperty rdf:about="http://example.org/ontology/nauclasssearchontology/course_academic_level">
        <rdfs:label>academic_level</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/nauclasssearchontology/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
