        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/nauclasssearchontology/courseOffering_catalog_number">
        <rdfs:label>catalog_number</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/nauclasssearchontology/CourseOffering"/>
