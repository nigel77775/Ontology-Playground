        <rdfs:label>units</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/nauclasssearchontology/Course"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Credit hours or course units.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/nauclasssearchontology/courseOffering_course_offering_key">
        <rdfs:label>course_offering_key</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/nauclasssearchontology/CourseOffering"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Business identifier for a Course_Offering, normally course_id + course_offer_number.</rdfs:comment>
