        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/nauclasssearchontology/courseOffering_offering_status">
        <rdfs:label>offering_status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/nauclasssearchontology/CourseOffering"/>
