        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/nauclasssearchontology/classSection_enrollment_capacity">
        <rdfs:label>enrollment_capacity</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/nauclasssearchontology/ClassSection"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
